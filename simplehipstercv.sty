% Replace the original \infobubble with a wrapped version
\newcommand{\infobubble}[4]{%
  \begin{tikzpicture}[baseline=(dot.base)]
    \node[circle, draw=#2, fill=#2, minimum size=0.42cm, inner sep=0pt] (dot) {};
    \node at (dot) {\color{#3}\bfseries\footnotesize #1};
    % reserve space for text; tweak the subtraction if needed
    \node[right=0.28cm, align=left,
          text width=\dimexpr\linewidth-2em\relax] at (dot.east)
          {\raggedright\small\ttfamily #4};
  \end{tikzpicture}%
}

\newcommand{\infos}[5]{%
  \begin{tikzpicture}[baseline=(dot.base)]
    \node[circle, draw=#3, fill=#3, minimum size=0.42cm, inner sep=0pt] (dot) {};
    \node at (dot) {\bg{#3}{#4}{\bfseries #1 #2}};
    % reserve space for text; tweak the subtraction if needed
    \node[right=0.35cm, align=left,
          text width=\dimexpr\linewidth-4em\relax] at (dot.east)
          {\raggedright\small #5};
  \end{tikzpicture}%
}

\newcommand{\info}[5]{%
  \begin{tikzpicture}[baseline=(dot.base)]
    % We move the coloring logic into the node styles directly
    \node[
        rectangle, 
        fill=#3,                % Background color of the circle
        text=#4,                % Text color
        minimum width=0.8cm,    % Rectangles need more width for 2-line text
        minimum height=0.5cm,   % Height to accommodate #1\\#2
        inner sep=2pt, 
        align=center,           % Essential for the \\ to work
        font=\bfseries\footnotesize     % Bold and tiny to fit the space
    ] (dot) {\ifstrempty{#1}{}{#1\\}#2};
    
    \node[right=0.125em, align=left,
          text width=\dimexpr\linewidth-3em\relax] at (dot.east)
          {\raggedright\small #5};
  \end{tikzpicture}%
}

