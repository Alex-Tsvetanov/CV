\NewDocumentCommand{\cvpublication}{O{} m m m m}{%
  \makecell[tr]{#2} & \textbf{#3} &
  \ifstrempty{#1}{}{\vspace{-0.7em}\centering\includegraphics[width=1cm,height=2em,keepaspectratio]{#1}}\\%
  & & \multicolumn{2}{p{\dimexpr0.75\linewidth+2\tabcolsep\relax}}{{\color{black!70}\cvdescsize\vspace{-0.75em}#4 \newline #5}}\\[1.75em]
}

