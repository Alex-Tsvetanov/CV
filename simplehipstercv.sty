%------------------------------------ pictoFraction
\newcommand{\icon}[3]{{#3\color{#2}#1}~}
%------------------- pictogram Fraction: pictoFraction
\newcommand{\pictofraction}[6]{%
  \pgfmathtruncatemacro{\filled}{#3}%
  \pgfmathtruncatemacro{\empty}{#5}%
  \ifnum\filled>0
    \foreach \n in {1,...,\filled}{\icon{#1}{#2}{#6}}%
  \fi
  \ifnum\empty>0
    \foreach \n in {1,...,\empty}{\icon{#1}{#4}{#6}}%
  \fi
}



