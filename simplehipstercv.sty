\usepackage{xparse}
\NewDocumentCommand{\projectitem}{O{} O{} m m m m m m}{%
    % #1 = note (e.g. "part of a patent application"), #2 = logo filename (optional)
    % #3 = url, #4 = project name, #5 = subtitle, #6 = personal / team, #7 = period (end\\start), #8 = items
    \noindent\begin{tabularx}{\linewidth}{p{0.125\linewidth} | X p{1cm}}
        {\makecell[tr]{#7}\hspace{0.2cm}} &
        \begin{minipage}[t]{\hsize}%
