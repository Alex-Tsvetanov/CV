\usepackage{xparse}
\NewDocumentCommand{\projectitem}{O{} O{} m m m m}{%
    % #1 = note (e.g. "part of a patent application"), #2 = logo filename (optional)
    % #3 = url, #4 = project name, #5 = subtitle, #6 = items
    \ifstrempty{#2}{%
        \noindent\makebox[\linewidth]{%
            \textbf{\href{#3}{#4} | #5}%
            \hfill
            \ifstrempty{#1}{}{\textit{#1}}%
        }%
        \begin{itemize}\color{black!70}#6\end{itemize}%
    }{%
        \noindent\begin{tabularx}{\linewidth}{X p{1cm}}
            \begin{minipage}[t]{\hsize}%
                \noindent\makebox[\hsize]{%
                    \textbf{\href{#3}{#4} | #5}%
                    \hfill
                    \ifstrempty{#1}{}{\textit{#1}}%
                }%
                \begin{itemize}\color{black!70}#6\end{itemize}%
            \end{minipage}%
            &
            \begin{minipage}[t]{1cm}\raisebox{-0.7\height}{\includegraphics[width=1cm]{#2}}\end{minipage}\\
        \end{tabularx}%
    }%
}

